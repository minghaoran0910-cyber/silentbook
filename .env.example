# SilentBook 环境变量配置

# ===== 数据库配置 =====
DB_USER=silentbook
DB_PASSWORD=silentbook
DB_NAME=silentbook
DATABASE_URL=postgresql://silentbook:silentbook@localhost:5432/silentbook

# ===== Agent 配置 =====
AGENT_API_URL=http://localhost:5000
MODEL_NAME=aliyun/glm-5.2

# 阿里云百炼 API Key（必填，用于 AI 分析功能）
# 获取方式：https://dashscope.aliyun.com
DASHSCOPE_API_KEY=

# ===== 前端配置 =====
# 浏览器端访问后端的地址（本地部署用 localhost）
NUXT_PUBLIC_API_BASE=http://localhost:8000
# SSR 端访问后端的地址（Docker 内部网络）
NUXT_SSR_API_BASE=http://backend:8000

# ===== 通知解析器配置 =====
PARSER_API_URL=http://localhost:6000

# ===== 后端配置 =====
# CORS 允许的来源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000

# ===== 部署模式 =====
# local - 全部本地（默认）
# hybrid - 混合部署（服务器前端+后端，本地数据库+Agent）
# cloud - 全部云端
DEPLOY_MODE=local

# ===== Agent Engine =====
# 分析模式: local (本地LLM) | openclaw (OpenClaw subagent) | auto (优先openclaw, fallback本地)
SILENTBOOK_MODE=auto
# OpenClaw Gateway 地址（openclaw/auto 模式需要）
OPENCLAW_GATEWAY_URL=http://localhost:18789
# 本地 LLM 配置（local/fallback 模式需要）
DASHSCOPE_API_KEY=
MODEL_NAME=aliyun/glm-5.2
