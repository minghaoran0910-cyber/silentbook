# SilentBook 环境变量配置

# 数据库配置
DB_USER=silentbook
DB_PASSWORD=***
DB_NAME=silentbook
DATABASE_URL=postgresql://silentbook:silentbook@localhost:5432/silentbook

# Agent 配置
AGENT_API_URL=http://localhost:5000
MODEL_NAME=aliyun/glm-5.2

# API 配置
API_BASE_URL=http://localhost:8000
PARSER_API_URL=http://localhost:6000

# 部署模式
# local - 全部本地（默认）
# hybrid - 混合部署（服务器前端+后端，本地数据库+Agent）
# cloud - 全部云端
DEPLOY_MODE=local
